<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_sendpulse_connect_list" model="ir.ui.view">
        <field name="name">sendpulse.connect.list</field>
        <field name="model">sendpulse.connect</field>
        <field name="arch" type="xml">
            <tree string="Розмови SendPulse"
                  decoration-danger="stage == 'new'"
                  decoration-warning="stage == 'new_message'"
                  decoration-muted="stage == 'close'"
                  create="false">
                <field name="name" string="Контакт"/>
                <field name="service" string="Канал"/>
                <field name="partner_id" string="Клієнт"/>
                <field name="social_username" string="Username"/>
                <field name="last_message_preview" string="Останнє повідомлення"/>
                <field name="last_message_date" string="Дата"/>
                <field name="stage" string="Статус"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_sendpulse_connect_form" model="ir.ui.view">
        <field name="name">sendpulse.connect.form</field>
        <field name="model">sendpulse.connect</field>
        <field name="arch" type="xml">
            <form string="Розмова SendPulse">
                <header>
                    <button name="action_open_discuss" type="object"
                            string="Відкрити чат" class="btn-primary"
                            invisible="stage == 'close'"/>
                    <button name="%(odoo_chatwoot_connector.action_sendpulse_identify_wizard)d"
                            string="Ідентифікувати клієнта"
                            type="action"
                            class="btn-warning"
                            invisible="partner_id != False or stage == 'close'"/>
                    <button name="action_close" type="object"
                            string="Закрити розмову"
                            invisible="stage == 'close'"
                            confirm="Закрити цю розмову?"/>
                    <button name="action_reopen" type="object"
                            string="Відновити"
                            invisible="stage != 'close'"/>
                    <field name="stage" widget="statusbar"
                           statusbar_visible="new,in_progress,new_message,close"/>
                </header>
                <sheet>
                    <group>
                        <group string="Клієнт">
                            <field name="partner_id" placeholder="Не ідентифікований"/>
                            <field name="unidentified_email" string="Email (з SendPulse)"
                                   invisible="partner_id != False"/>
                            <field name="unidentified_phone" string="Телефон"
                                   invisible="partner_id != False"/>
                        </group>
                        <group string="Канал">
                            <field name="service"/>
                            <field name="social_username" string="Username"/>
                            <field name="social_profile_url" string="URL профілю"/>
                            <field name="bot_name" string="Бот"/>
                        </group>
                    </group>
                    <group>
                        <group string="Оператори">
                            <field name="user_ids" widget="many2many_tags"/>
                        </group>
                        <group string="SendPulse">
                            <field name="sendpulse_contact_id" string="Contact ID"/>
                            <field name="last_message_date" string="Останнє повідомлення"/>
                            <field name="channel_id" string="Discuss Канал"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Повідомлення" name="messages">
                            <field name="message_ids" readonly="1">
                                <tree create="false">
                                    <field name="date" string="Дата"/>
                                    <field name="direction" string="Напрямок"/>
                                    <field name="text_message" string="Текст"/>
                                    <field name="attachment_url" string="Вкладення"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_sendpulse_connect_search" model="ir.ui.view">
        <field name="name">sendpulse.connect.search</field>
        <field name="model">sendpulse.connect</field>
        <field name="arch" type="xml">
            <search string="Пошук розмов">
                <field name="name" string="Ім'я контакту"/>
                <field name="partner_id" string="Клієнт"/>
                <field name="social_username" string="Username"/>
                <separator/>
                <filter name="filter_new" string="Нові" domain="[('stage','=','new')]"/>
                <filter name="filter_new_msg" string="Нові повідомлення" domain="[('stage','=','new_message')]"/>
                <filter name="filter_in_progress" string="В роботі" domain="[('stage','=','in_progress')]"/>
                <filter name="filter_unidentified" string="Не ідентифіковані" domain="[('partner_id','=',False)]"/>
                <filter name="filter_close" string="Закриті" domain="[('stage','=','close')]"/>
                <separator/>
                <filter name="filter_telegram" string="Telegram" domain="[('service','=','telegram')]"/>
                <filter name="filter_instagram" string="Instagram" domain="[('service','=','instagram')]"/>
                <filter name="filter_facebook" string="Facebook" domain="[('service','=','facebook')]"/>
                <separator/>
                <group string="Згрупувати за">
                    <filter name="group_service" string="Канал" context="{'group_by':'service'}"/>
                    <filter name="group_stage" string="Статус" context="{'group_by':'stage'}"/>
                    <filter name="group_partner" string="Клієнт" context="{'group_by':'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Settings Form -->
    <record id="view_sendpulse_config_form" model="ir.ui.view">
        <field name="name">sendpulse.config.form</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Налаштування SendPulse Odo">
                <header>
                    <button string="Зберегти" type="object" name="execute" class="btn-primary"/>
                    <button string="Скасувати" special="cancel"/>
                </header>
                <sheet>
                    <h2>SendPulse API</h2>
                    <group>
                        <group string="OAuth Авторизація">
                            <field name="sendpulse_client_id" placeholder="Client ID з SendPulse"/>
                            <field name="sendpulse_client_secret" password="True" placeholder="Client Secret"/>
                            <field name="sendpulse_webhook_token" placeholder="Секретний токен"/>
                        </group>
                        <group string="Webhook URL">
                            <field name="sendpulse_webhook_url" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Server Action: Sync Discuss channels -->
    <record id="action_sync_discuss_channels" model="ir.actions.server">
        <field name="name">Sync Discuss каналів</field>
        <field name="model_id" ref="model_sendpulse_connect"/>
        <field name="binding_model_id" ref="model_sendpulse_connect"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_sync_discuss_channels()</field>
        <field name="groups_id" eval="[(4, ref('odoo_chatwoot_connector.group_sendpulse_admin'))]"/>
    </record>

    <!-- Actions -->
    <record id="action_sendpulse_connect_all" model="ir.actions.act_window">
        <field name="name">Всі розмови</field>
        <field name="res_model">sendpulse.connect</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sendpulse_connect_search"/>
        <field name="context">{'search_default_filter_new': 1}</field>
    </record>

    <record id="action_sendpulse_connect_unidentified" model="ir.actions.act_window">
        <field name="name">Нові чати</field>
        <field name="res_model">sendpulse.connect</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('partner_id','=',False),('stage','!=','close')]</field>
    </record>

    <record id="action_sendpulse_webhook_data" model="ir.actions.act_window">
        <field name="name">Webhook Дані</field>
        <field name="res_model">sendpulse.webhook.data</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_sendpulse_config" model="ir.actions.act_window">
        <field name="name">Налаштування SendPulse</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_sendpulse_config_form"/>
        <field name="target">inline</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_sendpulse_root"
              name="SendPulse"
              sequence="90"
              groups="odoo_chatwoot_connector.group_sendpulse_officer"/>

    <menuitem id="menu_sendpulse_all"
              name="Всі розмови"
              parent="menu_sendpulse_root"
              action="action_sendpulse_connect_all"
              sequence="10"/>

    <menuitem id="menu_sendpulse_unidentified"
              name="Нові чати"
              parent="menu_sendpulse_root"
              action="action_sendpulse_connect_unidentified"
              sequence="20"/>

    <menuitem id="menu_sendpulse_config"
              name="Налаштування"
              parent="menu_sendpulse_root"
              action="action_sendpulse_config"
              sequence="80"
              groups="odoo_chatwoot_connector.group_sendpulse_admin"/>

    <menuitem id="menu_sendpulse_webhook_data"
              name="Webhook Дані"
              parent="menu_sendpulse_root"
              action="action_sendpulse_webhook_data"
              sequence="90"
              groups="odoo_chatwoot_connector.group_sendpulse_admin"/>

</odoo>
