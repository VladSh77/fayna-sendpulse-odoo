<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sendpulse_identify_wizard_form" model="ir.ui.view">
        <field name="name">sendpulse.identify.wizard.form</field>
        <field name="model">sendpulse.identify.wizard</field>
        <field name="arch" type="xml">
            <form string="Ідентифікація клієнта">

                <!-- Заголовок: дані з SendPulse -->
                <div class="alert alert-info mb-3" role="alert">
                    <strong>Клієнт з SendPulse:</strong>
                    <field name="connect_name" readonly="1" nolabel="1"
                           class="ms-1 fw-bold d-inline"/>
                    <span class="ms-2 text-muted">(
                        <field name="connect_service" readonly="1" nolabel="1"
                               class="d-inline"/>
                    )</span>
                </div>

                <!-- Поля пошуку -->
                <group string="Пошук за даними клієнта">
                    <field name="search_email"
                           placeholder="email@example.com"
                           attrs="{'required': [('search_phone', '=', False)]}"/>
                    <field name="search_phone"
                           placeholder="+380XXXXXXXXX"/>
                </group>

                <div class="mb-3">
                    <button name="action_search"
                            string="Знайти в базі"
                            type="object"
                            class="btn btn-primary"/>
                </div>

                <!-- Результати пошуку -->
                <group string="Результати пошуку"
                       invisible="not search_done">

                    <!-- Нічого не знайдено -->
                    <div invisible="found_count != 0"
                         class="alert alert-warning">
                        Клієнта з таким email/телефоном не знайдено в базі.
                        Можна створити нового клієнта.
                    </div>

                    <!-- Знайдено — список для вибору -->
                    <field name="found_partner_ids"
                           nolabel="1"
                           invisible="found_count == 0">
                        <tree string="Знайдені клієнти" create="False">
                            <field name="name" string="Ім'я"/>
                            <field name="email" string="Email"/>
                            <field name="phone" string="Телефон"/>
                            <field name="mobile" string="Мобільний"/>
                        </tree>
                    </field>

                    <field name="selected_partner_id"
                           string="Обрати клієнта"
                           domain="[('id', 'in', found_partner_ids)]"
                           invisible="found_count == 0"
                           placeholder="Оберіть зі списку вище"/>
                </group>

                <field name="search_done" invisible="1"/>
                <field name="found_count" invisible="1"/>

                <footer>
                    <!-- Прив'язати знайденого -->
                    <button name="action_link_partner"
                            string="Прив'язати обраного"
                            type="object"
                            class="btn-primary"
                            invisible="not selected_partner_id"/>

                    <!-- Відкрити картку для перевірки / merge -->
                    <button name="action_open_partner"
                            string="Відкрити картку"
                            type="object"
                            class="btn-secondary"
                            invisible="not selected_partner_id"/>

                    <!-- Створити нового клієнта -->
                    <button name="action_create_and_link"
                            string="Створити нового клієнта"
                            type="object"
                            class="btn-secondary"
                            invisible="not search_done"/>

                    <button string="Скасувати" special="cancel" class="btn-secondary"/>
                </footer>

            </form>
        </field>
    </record>

    <!-- Action для відкриття wizard -->
    <record id="action_sendpulse_identify_wizard" model="ir.actions.act_window">
        <field name="name">Ідентифікувати клієнта</field>
        <field name="res_model">sendpulse.identify.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_sendpulse_connect"/>
        <field name="context">{'default_connect_id': active_id}</field>
    </record>

</odoo>
